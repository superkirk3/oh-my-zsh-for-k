export DOTDIR=$HOME/.zshrc.d
export EDITOR_PATH=$HOME/.zshrc.d

export EMACS="*term*"
export SNIPPETS_PATH=$HOME/.config/snippets/
export PATH=$SNIPPETS_PATH:$PATH
export FZF_SNIPPETS_BINDKEYS='^[x ^[^['

DOOMDIR_MAC=~/.config/doom/
TRU_HISTFILE=~/.zsh_history
HISTDB_FILE=~/.histdb/zsh-history.db
devops_terraform_local_git=$HOME/work_home/uid.devops.terraform.git
export UID_TF_MODULES_BASE_PATH=$HOME/work_home/uid
export PATH="$HOME/.tgenv/bin:$PATH"
export PATH=/opt/homebrew/Cellar/emacs-plus@29/bin:$PATH
export PATH="/Applications/Cursor.app/Contents/Resources/app/bin:$PATH"
