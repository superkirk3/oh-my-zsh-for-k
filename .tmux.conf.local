#     send -X cursor-down
#     send -X next-word-end
#     send -X previous-word
#     send -X stop-selection
#   }
# }

bind -n C-M-n {
  copy-mode
  send -X clear-selection
  if -F "#{==:0,#{copy_cursor_x}}" {
    send -X cursor-down
    send -X end-of-line
  }
  send -X end-of-line
  send -X search-forward-text "❯"
  send -X end-of-line
  if -F "#{m:*❯*,#{copy_cursor_line}}" {
    send -X cursor-up
    send -X end-of-line
    # Home
    if -F "#{m:*\uF015*,#{copy_cursor_line}}" {
      send -X cursor-up
      send -X end-of-line
      send -X previous-word
      send -X next-word-end
    }
    # Folder white
    if -F "#{m:*\uF07C*,#{copy_cursor_line}}" {
      send -X cursor-up
      send -X end-of-line
      send -X previous-word
      send -X next-word-end
    }
    # System
    if -F "#{m:*\uF013*,#{copy_cursor_line}}" {
      send -X cursor-up
      send -X end-of-line
      send -X previous-word
      send -X next-word-end
    }
    # Folder black
    if -F "#{m:*\uF115*,#{copy_cursor_line}}" {
      send -X cursor-up
      send -X end-of-line
      send -X previous-word
      send -X next-word-end
    }
    if -F "#{m:*🏀*,#{copy_cursor_line}}" {
      send -X cursor-up
      send -X end-of-line
      send -X previous-word
      send -X next-word-end
    }
    send -X begin-selection
    send -X search-backward-text "❯"
    send -X cursor-down
    send -X next-word-end
    send -X previous-word
    send -X stop-selection
  }

}


