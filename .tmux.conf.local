bind-key w capture-pane \; save-buffer /tmp/tmux-buffer \; delete-buffer \; display-popup -w 90% -h 90% -E "$HOME/Documents/work_study/repo/shownotes/fzf_speed/_tmux_find_windows,--.search.all.window.and.jump"
